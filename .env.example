# --- Database ---
# MongoDB connection string (MongoDB Atlas or self-hosted)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=upkeep

# --- Admin access ---
# Plain admin password used only once, to generate ADMIN_PASSWORD_HASH.
# Run: node scripts/hash-password.js "your-password-here"
# Then paste the printed hash below and delete the plain password from your notes.
ADMIN_PASSWORD_HASH=$2b$12$Kuv/lfPsYy2kgDCMUNziGOU.IW7ZHxWJflzh8gDMutO9xdd1BgNF6


# Long random string used to sign admin session cookies.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=H/uOwpQAhP4QIT1cErWxRAuVuArXUI9DtRHVM9OrCmvJ0ywQFANfQTD4uFPlUgYn

# --- Read-only family link ---
# Long random, unguessable token. Anyone with this exact string + /view/<token>
# can see (but not edit) obligations. Generate with: openssl rand -hex 24
# You can also regenerate/rotate this from the admin Settings page later.
VIEW_TOKEN=93d2ed90e230bd84ac97fc573aa45d055233aff0d74bcd4f

# --- Email reminders (optional but recommended) ---
# Standard SMTP settings. Works with providers like Gmail (App Password),
# SendGrid, Postmark, Resend SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="UpKeep <reminders@yourdomain.com>"

# Comma-separated list of email addresses that receive reminder emails.
# (Can also be managed from the admin Settings page once running.)
NOTIFICATION_EMAILS=syedamaymoona8@gmail.com

# --- Cron protection ---
# Secret required in the Authorization header when the daily reminder job
# calls /api/cron/reminders. Generate with: openssl rand -hex 24
CRON_SECRET=b57b314b7722bc4800d5253849e3d42580a44d4a694cdb6a

# Timezone used to decide when "today" rolls over for due/overdue calculations.
TZ=Asia/Qatar
